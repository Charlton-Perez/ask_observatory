# Copy this to .env.local and fill in your values
# The Anthropic API key (kept server-side in Vercel)
ANTHROPIC_API_KEY=sk-ant-...

# The secret token users must include in their invite URL
# e.g. share: https://your-app.vercel.app/?token=YOUR_TOKEN_HERE
INVITE_TOKEN=change-me-to-something-secret

# This one is exposed to the browser (used to validate the token client-side)
VITE_INVITE_TOKEN=change-me-to-something-secret
