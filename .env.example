# ── Access control ────────────────────────────────────────────────────────────
# Secret token users must include in their invite URL:
# e.g. https://your-app.vercel.app/?token=YOUR_TOKEN_HERE
# Set the same value in both variables.
INVITE_TOKEN=change-me-to-something-secret
VITE_INVITE_TOKEN=change-me-to-something-secret


# ── Model provider switch ─────────────────────────────────────────────────────
# Change MODEL_PROVIDER + MODEL_NAME (+ MODEL_BASE_URL / MODEL_API_KEY as needed)
# in Vercel → Settings → Environment Variables, then redeploy. No code changes.

MODEL_PROVIDER=anthropic     # anthropic | ollama | openai | groq | mistral | gemini
MODEL_NAME=claude-haiku-4-5-20251001  # model ID for the chosen provider (see options below)
MODEL_BASE_URL=              # only needed for ollama (or to override a provider's default URL)
MODEL_API_KEY=               # API key for the chosen provider (see per-provider notes)


# ── Provider options ──────────────────────────────────────────────────────────

# 1. ANTHROPIC — claude-haiku-3-5 (cheap) or claude-sonnet-4-6 (best quality)
#    Register: console.anthropic.com
#    Green: AWS RECs; Haiku uses ~10x less compute than Sonnet
#
#    MODEL_PROVIDER=anthropic
#    MODEL_NAME=claude-haiku-4-5-20251001
#    MODEL_API_KEY=sk-ant-...           ← from console.anthropic.com/settings/keys

# 2. OLLAMA on HETZNER (greenest cloud option — Finnish hydro grid)
#    Register: cloud.hetzner.com
#    Server:   CX22 €3.79/mo (4GB, fine for 7-8B models)
#              CAX21 €3.29/mo (ARM, more efficient)
#              CCX13 €14/mo   (8GB, comfortable for 14B models)
#    Setup on server:
#      curl -fsSL https://ollama.com/install.sh | sh
#      OLLAMA_API_KEY=your-secret OLLAMA_HOST=0.0.0.0 ollama serve &
#      ollama pull qwen2.5:14b          ← or llama3.1, mistral, gemma2:9b
#    Cost: flat monthly server fee, unlimited queries
#    Green: ~97% hydroelectric
#
#    MODEL_PROVIDER=ollama
#    MODEL_NAME=qwen2.5:14b
#    MODEL_BASE_URL=http://YOUR-HETZNER-IP:11434
#    MODEL_API_KEY=your-secret          ← same value set as OLLAMA_API_KEY on server

# 3. GROQ — fastest inference, generous free tier, efficient custom hardware
#    Register: console.groq.com  (free, no card needed initially)
#    Green: custom LPU chips ~10x more efficient per token than GPU
#
#    MODEL_PROVIDER=groq
#    MODEL_NAME=llama-3.1-70b-versatile
#    MODEL_API_KEY=gsk_...              ← from console.groq.com/keys

# 4. MISTRAL — EU-based, GDPR-native, strong sustainability reporting
#    Register: console.mistral.ai
#    Green: French data centres, smallest major AI lab
#
#    MODEL_PROVIDER=mistral
#    MODEL_NAME=mistral-small-latest
#    MODEL_API_KEY=...                  ← from console.mistral.ai/api-keys

# 5. GOOGLE GEMINI — free tier (1,500 req/day via AI Studio)
#    Register: aistudio.google.com (free) or cloud.google.com (paid)
#    Green: claimed carbon neutral via RECs (see project docs for caveats)
#
#    MODEL_PROVIDER=gemini
#    MODEL_NAME=gemini-2.0-flash
#    MODEL_API_KEY=AIza...              ← from aistudio.google.com → Get API key

# 6. OPENAI
#    Register: platform.openai.com
#
#    MODEL_PROVIDER=openai
#    MODEL_NAME=gpt-4o-mini
#    MODEL_API_KEY=sk-...              ← from platform.openai.com/api-keys
